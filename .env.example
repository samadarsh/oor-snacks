# Supabase → Settings → API (copy all four into .env locally)

# Vite / storefront build (required for npm run dev & Vercel frontend build)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Vercel /api/supabase-config (same values — serverless often needs non-VITE names)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Legacy anon JWT (optional fallback)
# VITE_SUPABASE_ANON_KEY=eyJ...

# Server-only — never use VITE_ prefix (not bundled into the store)
SUPABASE_SECRET_KEY=sb_secret_xxx
